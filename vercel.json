{
  "buildCommand": "npm run build",
  "outputDirectory": "public_html",
  "headers": [
    {
      "source": "/vap-gallery.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
